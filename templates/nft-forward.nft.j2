#!/usr/sbin/nft -f
# Managed by Ansible — do not edit manually
# host={{ inventory_hostname }} env={{ deployment_env }}
# in={{ _nft_in_if }} out={{ _nft_out_if }} mark={{ nft_mark }}

table ip messup {
	chain prerouting {
		type nat hook prerouting priority dstnat; policy accept;
{% for m in _nft_mappings %}
{% if m.proto == 'tcp' %}
		iifname "{{ _nft_in_if }}" tcp dport {{ m.lport }} ct state new ct mark set {{ nft_mark }} dnat to {{ m.dip }}:{{ m.dport }}
{% elif m.proto == 'udp' %}
		iifname "{{ _nft_in_if }}" udp dport {{ m.lport }} ct state new ct mark set {{ nft_mark }} dnat to {{ m.dip }}:{{ m.dport }}
{% endif %}
{% endfor %}
	}

	chain postrouting {
		type nat hook postrouting priority srcnat; policy accept;
		oifname "{{ _nft_out_if }}" ct mark {{ nft_mark }} masquerade
	}

	chain forward {
		type filter hook forward priority filter; policy accept;
		ct mark {{ nft_mark }} accept
	}
}
